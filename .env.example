# ------------------------------
# Contact Form — API Gateway + Lambda (production)
# ------------------------------
# In production (static export), the contact form posts to this URL instead of
# the Next.js /api/contact route (which is not available in a static build).
# Set this to your API Gateway endpoint URL:
#   e.g. https://XXXX.execute-api.us-east-1.amazonaws.com/prod/contact
# Leave blank in local dev to use the built-in /api/contact fallback.
NEXT_PUBLIC_CONTACT_API_URL=

# ------------------------------
# AWS — Contact Form SES (local dev / server-mode only)
# ------------------------------
# These vars are used by the local Next.js API route (/api/contact) when
# NEXT_PUBLIC_CONTACT_API_URL is not set (dev mode).
# In production, set these on the Lambda function instead.
