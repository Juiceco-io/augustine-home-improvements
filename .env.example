# ============================================================
# Augustine Home Improvements — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# All deployment secrets should be set in GitHub environments.
# NEVER commit .env or .env.local to source control.
#
# Current immediate target: DEV
# See infra/dev-checklist.md for the step-by-step dev setup.

# ------------------------------
# Site
# ------------------------------
# Dev URL (override in GitHub `dev` environment vars as SITE_URL)
SITE_URL=https://dev.augustinehomeimprovements.com
# Local app URL used for Cognito callback during local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------
# Contact Form — API Gateway + Lambda
# ------------------------------
# In deployed environments, the contact form posts to this AWS API Gateway URL.
# Leave blank locally to fall back to the built-in /api/contact route.
# Example dev URL:
#   https://XXXX.execute-api.us-east-1.amazonaws.com/dev/contact
NEXT_PUBLIC_CONTACT_API_URL=

# ------------------------------
# AWS — Contact Form SES (local dev / server fallback only)
# ------------------------------
# These vars are used only by the local Next.js /api/contact fallback when
# NEXT_PUBLIC_CONTACT_API_URL is blank. In AWS, set these on the Lambda function.
SES_FROM_EMAIL=noreply@augustinehomeimprovements.com
CONTACT_RECIPIENT_EMAIL=info@augustinehomeimprovements.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ------------------------------
# Admin Panel — Amazon Cognito
# ------------------------------
# Hosted UI domain, e.g. https://augustine-admin.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
# Optional comma-separated allowlist for super-user bootstrap
COGNITO_SUPERUSER_EMAILS=
# Strong random string (min 32 chars) used to sign the local app session after Cognito login
ADMIN_SESSION_SECRET=

# ------------------------------
# ISR Revalidation
# ------------------------------
ISR_REVALIDATION_SECRET=

# ------------------------------
# AWS — Infrastructure (CI/CD)
# ------------------------------
# IAM role for GitHub Actions OIDC (dev role, not prod)
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/augustine-deploy-role-dev
# Dev bucket / distribution placeholders if used
S3_BUCKET_NAME=augustine-home-improvements-dev
CLOUDFRONT_DISTRIBUTION_ID=

# ------------------------------
# Google Analytics (optional)
# ------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BG798Y9ZT0
