# ============================================================
# Augustine Home Improvements — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# All production secrets are set in GitHub environment secrets.
# NEVER commit .env or .env.local to source control.

# ------------------------------
# Site
# ------------------------------
SITE_URL=https://www.augustinehomeimprovements.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------
# AWS — Contact Form (SES)
# ------------------------------
# SES sender + recipient are environment-specific secrets.
# Region is fixed in code to us-east-1.
SES_FROM_EMAIL=noreply@augustinehomeimprovements.com
CONTACT_RECIPIENT_EMAIL=info@augustinehomeimprovements.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ------------------------------
# Admin Panel — Amazon Cognito
# ------------------------------
# Hosted UI domain, e.g. https://augustine-admin.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
# Optional comma-separated allowlist for the initial super-user bootstrap.
COGNITO_SUPERUSER_EMAILS=
# Strong random string (min 32 chars) used to sign the local app session after Cognito login.
ADMIN_SESSION_SECRET=

# ------------------------------
# ISR Revalidation
# ------------------------------
ISR_REVALIDATION_SECRET=

# ------------------------------
# AWS — Infrastructure (CI/CD)
# ------------------------------
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/augustine-deploy-role
S3_BUCKET_NAME=augustine-home-improvements-prod
CLOUDFRONT_DISTRIBUTION_ID=

# ------------------------------
# Google Analytics (optional)
# ------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BG798Y9ZT0
