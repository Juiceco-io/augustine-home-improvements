# ============================================================
# Augustine Home Improvements — Environment Variables
# Static export mode: no server runtime.
# ============================================================
# Copy this file to .env.local for local development.
#
# CI/CD (GitHub Actions): these values are NOT manually set as
# GitHub environment variables. They are read directly from
# Terraform outputs after `terraform apply` and injected into
# the Next.js build automatically. See .github/workflows/deploy.yml.
#
# NEVER commit .env or .env.local to source control.

# ------------------------------
# Contact Form (optional)
# ------------------------------
# AWS API Gateway URL that receives contact form POST submissions.
# Not wired yet — leave blank for fake-success UX (dev/preview builds).
NEXT_PUBLIC_CONTACT_API_URL=

# ------------------------------
# CMS Admin — Cognito authentication
# ------------------------------
# These are PUBLIC config values (not secrets). The Cognito app client
# has no client secret — it is intentionally public-facing.
#
# In CI/CD these are injected automatically from Terraform outputs:
#   cms_cognito_user_pool_id → NEXT_PUBLIC_COGNITO_USER_POOL_ID
#   cms_cognito_client_id    → NEXT_PUBLIC_COGNITO_CLIENT_ID
#
# For local dev, run: terraform output -raw cms_cognito_user_pool_id
# (from the infrastructure/ directory) and paste the value below.
#
# Cognito User Pool ID (format: us-east-1_XXXXXXXXX)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=

# Cognito App Client ID (no client secret — public SPA client)
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# ------------------------------
# CMS Admin — API Gateway
# ------------------------------
# Base URL of the CMS API Gateway (no trailing slash).
#
# In CI/CD injected from Terraform output: cms_api_url
# For local dev: terraform output -raw cms_api_url
#
# Example: https://abc123.execute-api.us-east-1.amazonaws.com/dev
NEXT_PUBLIC_CMS_API_URL=

# ------------------------------
# Build metadata
# ------------------------------
NEXT_PUBLIC_APP_VERSION=local
