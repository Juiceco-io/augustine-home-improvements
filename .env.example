# ============================================================
# Augustine Home Improvements — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# All production secrets are set in GitHub Secrets / Vercel env.
# NEVER commit .env or .env.local to source control.

# ------------------------------
# Site
# ------------------------------
SITE_URL=https://www.augustinehomeimprovements.com

# ------------------------------
# AWS — Contact Form (SES)
# ------------------------------
# SES-verified sender email address
SES_FROM_EMAIL=noreply@augustinehomeimprovements.com

# Brandon's email where form submissions are delivered
CONTACT_RECIPIENT_EMAIL=info@augustinehomeimprovements.com

# AWS credentials (prefer IAM role / OIDC in production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ------------------------------
# Admin Panel
# ------------------------------
# Strong random string (min 32 chars)
ADMIN_JWT_SECRET=

# Admin username (default: admin)
ADMIN_USERNAME=admin

# bcrypt hash of admin password
# Generate with: node -e "const b = require('bcryptjs'); b.hash('yourpassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# ------------------------------
# ISR Revalidation
# ------------------------------
# Secret for /api/revalidate webhook
ISR_REVALIDATION_SECRET=

# ------------------------------
# AWS — Infrastructure (CI/CD)
# ------------------------------
# Preferred: use OIDC role instead of static keys
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/augustine-deploy-role
S3_BUCKET_NAME=augustine-home-improvements-prod
CLOUDFRONT_DISTRIBUTION_ID=

# ------------------------------
# Google Analytics (optional)
# ------------------------------
# GA4 Measurement ID — preserves existing tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BG798Y9ZT0
