# ============================================================
# Augustine Home Improvements — Environment Variables
# Static export mode: no server runtime.
# ============================================================
# Copy this file to .env.local for local development.
# In CI/CD, set via GitHub Actions environment variables.
# NEVER commit .env or .env.local to source control.

# ------------------------------
# Contact Form (optional)
# ------------------------------
# AWS API Gateway URL that receives contact form POST submissions.
# Not wired yet — leave blank for fake-success UX (dev/preview builds).
NEXT_PUBLIC_CONTACT_API_URL=

# ------------------------------
# CMS — config fetch (public site)
# ------------------------------
# Full URL to site-config.json on the CloudFront CDN.
# Get this value from Terraform output: cms_config_url
# Leave blank to use hardcoded defaultConfig (site still works, just not CMS-driven).
# Example: https://d1abc123.cloudfront.net/config/site-config.json
NEXT_PUBLIC_CMS_CONFIG_URL=

# ------------------------------
# Build metadata
# ------------------------------
NEXT_PUBLIC_APP_VERSION=local
