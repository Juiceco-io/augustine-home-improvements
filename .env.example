# ============================================================
# Augustine Home Improvements — Environment Variables
# Static export mode: no server runtime, no admin/CMS.
# ============================================================
# Copy this file to .env.local for local development.
# In CI/CD, these are GitHub Actions environment variables.
# NEVER commit .env or .env.local to source control.

# ------------------------------
# Contact Form (optional at build time)
# ------------------------------
# AWS API Gateway URL that receives contact form POST submissions.
# In production, this is output by Terraform as `contact_api_url`.
# Leave blank locally to skip form submission (dev/preview builds).
NEXT_PUBLIC_CONTACT_API_URL=

# ------------------------------
# Google Analytics (optional)
# ------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BG798Y9ZT0

# ------------------------------
# Build metadata
# ------------------------------
NEXT_PUBLIC_APP_VERSION=local
