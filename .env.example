# ============================================================
# Augustine Home Improvements — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local to source control.
#
# Deployment model:
#   - Cognito and AWS infrastructure are managed via Terraform/IaC
#     and provisioned through PRs — NOT manually in the AWS Console.
#   - Non-sensitive config lives in GitHub environment *variables* (vars.*).
#   - Only truly secret values (tokens, secrets, credentials) are stored
#     as GitHub environment *secrets* (secrets.*).
#   - Locally, copy this file to .env.local and fill in what you need.
#
# See docs/deployment-model.md for the full vars/secrets reference.

# ------------------------------
# Site
# ------------------------------
# Default: dev URL. Override via GitHub environment variable SITE_URL.
SITE_URL=https://dev.augustinehomeimprovements.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------
# Contact Form — API Gateway + Lambda
# ------------------------------
# The contact form posts to this AWS API Gateway URL in deployed environments.
# Leave blank locally to fall back to the built-in /api/contact route.
# Set as GitHub env variable CONTACT_API_URL (not a secret — just a URL).
# Example: https://XXXX.execute-api.us-east-1.amazonaws.com/dev/contact
NEXT_PUBLIC_CONTACT_API_URL=

# ------------------------------
# AWS — Contact Form (local dev / server fallback only)
# ------------------------------
# Used only when NEXT_PUBLIC_CONTACT_API_URL is blank (local dev fallback).
# In deployed environments, set these on the Lambda function directly.
# SES_FROM_EMAIL and CONTACT_RECIPIENT_EMAIL are not secrets — they are
# email addresses and can be set as vars or code defaults.
SES_FROM_EMAIL=noreply@augustinehomeimprovements.com
CONTACT_RECIPIENT_EMAIL=info@augustinehomeimprovements.com
# AWS credentials for local SES access (never needed in CI/CD — use OIDC there).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ------------------------------
# Admin Panel — Amazon Cognito
# ------------------------------
# Cognito is provisioned via Terraform (PR-managed). These values are
# output by Terraform and then set as GitHub environment variables/secrets.
#
# Non-sensitive (set as GitHub env *variables*):
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=https://augustine-admin-dev.auth.us-east-1.amazoncognito.com
#
# Secrets (set as GitHub env *secrets*):
ADMIN_SESSION_SECRET=                  # min 32 chars — generate: openssl rand -hex 32
# Optional: comma-separated emails to bootstrap Cognito super-user via CI
COGNITO_SUPERUSER_EMAILS=

# ------------------------------
# ISR Revalidation
# ------------------------------
# Secret token used to trigger on-demand revalidation.
# Set as a GitHub env secret; generate with: openssl rand -hex 16
ISR_REVALIDATION_SECRET=

# ------------------------------
# AWS — Deployment (CI/CD secrets)
# ------------------------------
# Only needed in GitHub Actions, not locally.
# AWS_ROLE_ARN — IAM OIDC role for GitHub Actions
# ECR_REGISTRY, ECS_CLUSTER, ECS_SERVICE, CLOUDFRONT_DISTRIBUTION_ID
# are set as GitHub env secrets in each environment (dev/production).

# ------------------------------
# Google Analytics (optional)
# ------------------------------
# Non-sensitive — set as a GitHub env variable, not a secret.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BG798Y9ZT0
