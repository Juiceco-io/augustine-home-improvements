# Augustine CMS Admin — Environment Variables
# Copy to .env.local for local development.
# In CI, set these as GitHub Actions secrets/vars.

# API Gateway invoke URL (from Terraform output: cms_api_url)
VITE_API_URL=

# Cognito User Pool ID (from Terraform output: cms_cognito_user_pool_id)
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (from Terraform output: cms_cognito_client_id)
VITE_COGNITO_CLIENT_ID=

# CloudFront CDN base URL (from Terraform output: cms_cdn_domain)
VITE_CDN_BASE_URL=
